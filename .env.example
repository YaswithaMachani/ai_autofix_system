# AI provider (Groq or OpenAI — OpenAI-compatible API)
OPENAI_API_KEY=
OPENAI_MODEL=
AI_BASE_URL=

# GitHub (fine-grained or classic PAT with repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BASE_BRANCH=main

# Discord webhook for failed autofix attempts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Autofix behavior
MAX_AI_FIX_ATTEMPTS=3
SAMPLE_APP_PATH=sample-app
ALLOWED_EDIT_PATHS=sample-app
PROJECT_ROOT=.

# Express API (optional orchestration / n8n callbacks)
PORT=3847
API_SECRET=change-me-in-production

# Docker sandbox
DOCKER_IMAGE=ai-autofix-sandbox
DOCKER_NETWORK=none

# Logging
LOG_LEVEL=info
LOG_DIR=logs
ERROR_LOG_FILE=logs/error.log
PIPELINE_LOG_FILE=logs/pipeline.log

# n8n / CI
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/autofix
ORCHESTRATOR_URL=http://localhost:3847
PROTECTED_BRANCHES=main,master

# -------------------------------------------------------
# 🌍 UNIVERSAL PLATFORM SUPPORT
# Set these based on your project's language/framework
# -------------------------------------------------------

# Language hint: node | python | generic
LANGUAGE=node

# Test command — what runs your tests
# Node.js / MERN:   npm test
# Python:           pytest
# Python unittest:  python -m unittest discover
# Go:               go test ./...
# Rust:             cargo test
# Java (Maven):     mvn test
TEST_COMMAND=npm test

# Lint command — what checks your code style (set to "none" to skip)
# Node.js:          npm run lint
# Python flake8:    flake8 .
# Python pylint:    pylint src/
# Go:               go vet ./...
# Rust:             cargo clippy
# Java:             none
LINT_COMMAND=npm run lint
