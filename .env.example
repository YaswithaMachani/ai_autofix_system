# AI provider (Groq or OpenAI — OpenAI-compatible API)
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1

# GitHub (fine-grained or classic PAT with repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BASE_BRANCH=main

# Discord webhook for failed autofix attempts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Autofix behavior
MAX_AI_FIX_ATTEMPTS=3
SAMPLE_APP_PATH=sample-app
ALLOWED_EDIT_PATHS=sample-app
PROJECT_ROOT=.

# Express API (optional orchestration / n8n callbacks)
PORT=3847
API_SECRET=change-me-in-production

# Docker sandbox
DOCKER_IMAGE=ai-autofix-sandbox
DOCKER_NETWORK=none

# Logging
LOG_LEVEL=info
LOG_DIR=logs
ERROR_LOG_FILE=logs/error.log
PIPELINE_LOG_FILE=logs/pipeline.log

# n8n / CI
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/autofix
ORCHESTRATOR_URL=http://localhost:3847
PROTECTED_BRANCHES=main,master
